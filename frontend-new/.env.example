# Base HTTP API (Express backend). Includes the /api prefix.
VITE_API_URL=http://localhost:5000/api
# Socket.IO origin (no /api prefix).
VITE_SOCKET_URL=http://localhost:5000
# Cloudinary cloud name (Dashboard → Product Environment Credentials).
VITE_CLOUDINARY_CLOUD_NAME=
# Cloudinary UNSIGNED upload preset (Settings → Upload → Upload presets → Signing Mode: Unsigned).
VITE_CLOUDINARY_UPLOAD_PRESET=
